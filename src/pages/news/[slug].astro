---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('news');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={article.data.title}>
  <div class="content-page">
    <div class="container">
      <span class="news-date">{article.data.date.toLocaleDateString('de-CH', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      <h1>{article.data.title}</h1>
      {article.data.image && (
        <Image
          src={article.data.image}
          alt={article.data.title}
          loading="lazy"
          class="article-hero-image"
        />
      )}
      <div class="article-body">
        <Content />
      </div>
      <a href={`${base}/news`} class="back-link">← Zurück zur Übersicht</a>
    </div>
  </div>
</BaseLayout>

<style>
  .article-hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    margin: 1.5rem 0;
    display: block;
  }
</style>
