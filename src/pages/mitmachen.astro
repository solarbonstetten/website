---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Mitmachen"
  description="Werde Mitglied bei solarbonstetten und unterstütze Solarenergie in Bonstetten."
>

  <!-- Hero -->
  <div class="relative overflow-hidden" style="padding: 11rem 0 5rem">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Dabei sein</span>
      <h1 class="mb-4">Mitglied werden</h1>
      <p class="text-lg text-slate-500 max-w-xl leading-relaxed">
        Unterstütze Solarenergie in Bonstetten – als Aktivmitglied oder Gönnermitglied.
        Fülle das Formular aus und dein E-Mail-Programm öffnet sich mit der vorausgefüllten Beitrittserklärung.
      </p>
    </div>
  </div>

  <!-- Inhalt -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-12 items-start">

        <!-- Formular -->
        <div>
          <form id="beitrittsform" novalidate class="flex flex-col gap-8">

            <fieldset class="border border-slate-200 rounded-2xl px-7 py-6">
              <legend class="text-xs font-bold uppercase tracking-widest text-slate-900 px-2">Persönliche Angaben</legend>
              <div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
                <div class="flex flex-col gap-1.5 mt-4">
                  <label for="vorname" class="text-sm font-medium text-slate-900">Vorname <span class="text-amber-700">*</span></label>
                  <input type="text" id="vorname" name="vorname" required autocomplete="given-name" class="input-field" />
                </div>
                <div class="flex flex-col gap-1.5 mt-4">
                  <label for="name" class="text-sm font-medium text-slate-900">Name <span class="text-amber-700">*</span></label>
                  <input type="text" id="name" name="name" required autocomplete="family-name" class="input-field" />
                </div>
              </div>
              <div class="flex flex-col gap-1.5 mt-4">
                <label for="strasse" class="text-sm font-medium text-slate-900">Strasse <span class="text-amber-700">*</span></label>
                <input type="text" id="strasse" name="strasse" required autocomplete="street-address" class="input-field" />
              </div>
              <div class="grid grid-cols-[100px_1fr] gap-4 max-sm:grid-cols-1">
                <div class="flex flex-col gap-1.5 mt-4">
                  <label for="plz" class="text-sm font-medium text-slate-900">PLZ <span class="text-amber-700">*</span></label>
                  <input type="text" id="plz" name="plz" required autocomplete="postal-code" maxlength="4" class="input-field" />
                </div>
                <div class="flex flex-col gap-1.5 mt-4">
                  <label for="ort" class="text-sm font-medium text-slate-900">Ort <span class="text-amber-700">*</span></label>
                  <input type="text" id="ort" name="ort" required autocomplete="address-level2" class="input-field" />
                </div>
              </div>
              <div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
                <div class="flex flex-col gap-1.5 mt-4">
                  <label for="telefon" class="text-sm font-medium text-slate-900">Telefon</label>
                  <input type="tel" id="telefon" name="telefon" autocomplete="tel" class="input-field" />
                </div>
                <div class="flex flex-col gap-1.5 mt-4">
                  <label for="email" class="text-sm font-medium text-slate-900">E-Mail <span class="text-amber-700">*</span></label>
                  <input type="email" id="email" name="email" required autocomplete="email" class="input-field" />
                </div>
              </div>
            </fieldset>

            <fieldset class="border border-slate-200 rounded-2xl px-7 py-6">
              <legend class="text-xs font-bold uppercase tracking-widest text-slate-900 px-2">Mitgliedschaft</legend>
              <div class="grid grid-cols-2 gap-4 mt-4 max-sm:grid-cols-1">
                <label class="cursor-pointer">
                  <input type="radio" name="mitgliedschaft" value="Aktivmitglied (CHF 40.– / Jahr)" required class="sr-only peer" />
                  <div class="border-2 border-slate-200 rounded-xl p-4 transition-all hover:border-amber-400 peer-checked:border-amber-400 peer-checked:bg-amber-50">
                    <div class="flex justify-between items-center mb-1">
                      <span class="font-semibold text-slate-900 text-sm">Aktivmitglied</span>
                      <span class="font-bold text-amber-700 text-sm">CHF 40.– / Jahr</span>
                    </div>
                    <p class="text-xs text-slate-500 m-0">Mit Stimmberechtigung an der Generalversammlung</p>
                  </div>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="mitgliedschaft" value="Gönnermitglied (CHF 100.– / Jahr)" class="sr-only peer" />
                  <div class="border-2 border-slate-200 rounded-xl p-4 transition-all hover:border-amber-400 peer-checked:border-amber-400 peer-checked:bg-amber-50">
                    <div class="flex justify-between items-center mb-1">
                      <span class="font-semibold text-slate-900 text-sm">Gönnermitglied</span>
                      <span class="font-bold text-amber-700 text-sm">CHF 100.– / Jahr</span>
                    </div>
                    <p class="text-xs text-slate-500 m-0">Unterstützung ohne Stimmberechtigung</p>
                  </div>
                </label>
              </div>
            </fieldset>

            <fieldset class="border border-slate-200 rounded-2xl px-7 py-6">
              <legend class="text-xs font-bold uppercase tracking-widest text-slate-900 px-2">Optionale Angaben</legend>
              <div class="flex flex-col gap-3 mt-4">
                <label class="flex items-start gap-3 cursor-pointer text-sm text-slate-500">
                  <input type="checkbox" name="solarstrom" id="solarstrom" class="w-4 h-4 mt-0.5 accent-amber-400 shrink-0 cursor-pointer" />
                  <span>Ich möchte von solarbonstetten Solarstrom beziehen.</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer text-sm text-slate-500">
                  <input type="checkbox" name="aktiv" id="aktiv" class="w-4 h-4 mt-0.5 accent-amber-400 shrink-0 cursor-pointer" />
                  <span>Ich möchte im Verein solarbonstetten aktiv mitarbeiten.</span>
                </label>
              </div>
            </fieldset>

            <div id="form-error" class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 text-red-600 text-sm" hidden>
              Bitte fülle alle Pflichtfelder aus und wähle eine Mitgliedschaft.
            </div>

            <button type="submit" class="btn btn-primary w-full justify-center text-base py-4">
              📧 Beitrittserklärung per E-Mail senden
            </button>
            <p class="text-xs text-slate-400 text-center -mt-6">
              Dein E-Mail-Programm öffnet sich mit der vorausgefüllten Beitrittserklärung –
              du kannst den Text vor dem Senden noch überprüfen.
            </p>

            <div class="flex items-center gap-4 bg-slate-50 border border-slate-200 rounded-xl px-5 py-4">
              <span class="text-2xl shrink-0">🖨️</span>
              <div class="flex-1 min-w-0">
                <strong class="block text-sm text-slate-900 mb-0.5">Lieber per Post?</strong>
                <p class="text-xs text-slate-500 leading-relaxed m-0">Beitrittserklärung als PDF herunterladen, ausdrucken und an <a href="mailto:info@solarbonstetten.ch" class="text-amber-700">info@solarbonstetten.ch</a> senden oder per Post an: solarbonstetten, Dorfstrasse 24, 8906 Bonstetten.</p>
              </div>
              <a href="/dokumente/vereinsbeitritt.pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline text-sm shrink-0">
                PDF ↓
              </a>
            </div>

          </form>
        </div>

        <!-- Sidebar -->
        <aside class="flex flex-col gap-5 lg:sticky top-24">

          <!-- So funktioniert es -->
          <div class="bg-amber-400 text-white rounded-2xl p-6">
            <h3 class="text-base font-bold mb-4 text-white">So funktioniert es</h3>
            <ol class="list-none p-0 flex flex-col gap-2.5">
              {[
                'Formular ausfüllen',
                '«Per E-Mail senden» klicken',
                'E-Mail-Programm öffnet sich mit vorausgefüllter Beitrittserklärung',
                'Absenden – fertig!',
              ].map((step, i) => (
                <li class="flex items-start gap-3 text-sm opacity-95">
                  <span class="w-6 h-6 bg-white/25 rounded-full flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">{i + 1}</span>
                  {step}
                </li>
              ))}
            </ol>
          </div>

          <!-- Fragen -->
          <div class="bg-white border border-slate-200 shadow-sm rounded-2xl p-6">
            <h3 class="text-base font-bold mb-2 text-slate-900">Fragen?</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-3">Bei Fragen zur Mitgliedschaft erreichst du uns unter:</p>
            <a href="mailto:info@solarbonstetten.ch" class="text-amber-700 font-semibold text-sm break-all">info@solarbonstetten.ch</a>
          </div>

          <!-- Statuten -->
          <div class="bg-white border border-slate-200 shadow-sm rounded-2xl p-6">
            <h3 class="text-base font-bold mb-2 text-slate-900">Statuten</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-3">Mehr über Rechte und Pflichten der Mitglieder:</p>
            <a href="/statuten" class="text-amber-700 font-semibold text-sm hover:underline">Statuten lesen →</a>
          </div>

        </aside>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .input-field {
    width: 100%;
    padding: 0.6rem 0.875rem;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    font-size: 0.95rem;
    color: var(--color-secondary);
    background: #fff;
    transition: border-color 0.2s;
  }
  .input-field:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(251, 168, 3, 0.15);
  }
  .input-field.invalid { border-color: #ef4444; }
</style>

<script>
  const form = document.getElementById('beitrittsform') as HTMLFormElement;
  const errorBox = document.getElementById('form-error') as HTMLElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    errorBox.hidden = true;

    const required = ['vorname', 'name', 'strasse', 'plz', 'ort', 'email'];
    let valid = true;

    required.forEach(id => {
      const el = form.elements.namedItem(id) as HTMLInputElement;
      if (!el.value.trim()) {
        el.classList.add('invalid');
        valid = false;
      } else {
        el.classList.remove('invalid');
      }
    });

    const mitgliedschaft = (form.elements.namedItem('mitgliedschaft') as RadioNodeList).value;
    if (!mitgliedschaft) valid = false;

    if (!valid) {
      errorBox.hidden = false;
      errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const get = (id: string) => (form.elements.namedItem(id) as HTMLInputElement).value.trim();
    const checked = (id: string) => (form.elements.namedItem(id) as HTMLInputElement).checked;

    const optionen: string[] = [];
    if (checked('solarstrom')) optionen.push('Solarstrom beziehen: Ja');
    if (checked('aktiv'))      optionen.push('Aktive Mitarbeit: Ja');

    const body = [
      'Beitrittserklärung solarbonstetten',
      '─'.repeat(35),
      '',
      `Vorname:        ${get('vorname')}`,
      `Name:           ${get('name')}`,
      `Strasse:        ${get('strasse')}`,
      `PLZ / Ort:      ${get('plz')} ${get('ort')}`,
      `Telefon:        ${get('telefon') || '–'}`,
      `E-Mail:         ${get('email')}`,
      '',
      `Mitgliedschaft: ${mitgliedschaft}`,
      ...(optionen.length ? ['', ...optionen] : []),
      '',
      '─'.repeat(35),
      'Diese Beitrittserklärung wurde über solarbonstetten.ch ausgefüllt.',
    ].join('\n');

    const subject = 'Beitrittserklärung solarbonstetten';
    window.location.href =
      `mailto:info@solarbonstetten.ch?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });

  form.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', () => input.classList.remove('invalid'));
  });
</script>
