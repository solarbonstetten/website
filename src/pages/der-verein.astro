---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('derVerein');
const page = entries[0];
const { Content } = await render(page);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="Der Verein"
  description="solarbonstetten – ein Verein für Solarenergie in Bonstetten. Gegründet 2011, nicht gewinnorientiert, ehrenamtlich."
>

  <!-- Hero -->
  <div class="relative overflow-hidden" style="padding: 11rem 0 5rem">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Über uns</span>
      <h1 class="mb-3">{page.data.title}</h1>
      <p class="text-lg text-slate-500 max-w-xl leading-relaxed mb-6">{page.data.untertitel}</p>
      <div class="flex gap-3 flex-wrap">
        <span class="text-sm font-medium bg-white/70 border border-slate-200 px-4 py-1.5 rounded-full text-slate-900">📅 Gegründet {page.data.gruendungsdatum}</span>
        <span class="text-sm font-medium bg-white/70 border border-slate-200 px-4 py-1.5 rounded-full text-slate-900">🤝 Nicht gewinnorientiert</span>
        <span class="text-sm font-medium bg-white/70 border border-slate-200 px-4 py-1.5 rounded-full text-slate-900">🌱 Ehrenamtlich</span>
      </div>
    </div>
  </div>

  <!-- Inhalt -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 items-start">

        <!-- Hauptinhalt (Markdown) -->
        <div class="verein-content">
          <Content />
        </div>

        <!-- Sidebar -->
        <aside class="flex flex-col gap-5 lg:sticky top-24">

          <!-- Mitglied werden -->
          <div class="bg-amber-400 text-slate-900 rounded-2xl p-6">
            <h3 class="text-lg font-bold mb-3">Mitglied werden</h3>
            <p class="text-sm mb-5 leading-relaxed">Unterstütze Solarenergie in Bonstetten – als Aktivmitglied oder Gönnermitglied.</p>
            <ul class="flex flex-col gap-2 mb-5 list-none p-0">
              <li class="flex justify-between items-center bg-black/10 rounded-xl px-3 py-2 text-sm">
                <span class="font-bold">CHF 40</span>
                <span class="text-xs text-slate-700">Aktivmitglied / Jahr</span>
              </li>
              <li class="flex justify-between items-center bg-black/10 rounded-xl px-3 py-2 text-sm">
                <span class="font-bold">CHF 100</span>
                <span class="text-xs text-slate-700">Gönnermitglied / Jahr</span>
              </li>
            </ul>
            <a href={`${base}/mitmachen`} class="btn btn-primary block w-full text-center">
              Jetzt beitreten
            </a>
          </div>

          <!-- Statuten -->
          <div class="bg-white border border-slate-200 shadow-sm rounded-2xl p-6">
            <h3 class="text-lg font-bold mb-2 text-slate-900">Statuten</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-3">Die Organisationsform des Vereins ist in den Statuten festgehalten.</p>
            <a href={`${base}/statuten`} class="text-amber-700 font-semibold text-sm hover:underline">Statuten lesen →</a>
          </div>

          <!-- Kontakt -->
          <div class="bg-white border border-slate-200 shadow-sm rounded-2xl p-6">
            <h3 class="text-lg font-bold mb-3 text-slate-900">Kontakt</h3>
            <address class="not-italic text-sm text-slate-500 leading-loose">
              solarbonstetten<br />
              Dorfstrasse 24<br />
              8906 Bonstetten<br />
              <a href="mailto:info@solarbonstetten.ch" class="text-amber-700">info@solarbonstetten.ch</a>
            </address>
          </div>

        </aside>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Scoped styles für gerenderten Markdown-Inhalt */
  .verein-content :global(h2) {
    font-size: 1.35rem;
    color: var(--color-secondary);
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }
  .verein-content :global(p),
  .verein-content :global(li) {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 0.6rem;
  }
  .verein-content :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .verein-content :global(strong) { color: var(--color-secondary); }
</style>
