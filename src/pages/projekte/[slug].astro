---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projekte = await getCollection('projekte');
  return projekte.map((projekt) => ({
    params: { slug: projekt.id },
    props: { projekt },
  }));
}

const { projekt } = Astro.props;
const { Content } = await render(projekt);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={projekt.data.title}>
  <div style="padding: 10rem 0 6rem">
    <div class="container max-w-3xl">
      <h1 class="mb-6">{projekt.data.title}</h1>
      <div class="article-body">
        <Content />
      </div>
      <a href={`${base}/projekte`} class="inline-block mt-12 font-semibold text-sm text-slate-500 hover:text-amber-500 transition-colors">
        ← Zurück zur Übersicht
      </a>
    </div>
  </div>
</BaseLayout>
