---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const alleAnlagen = await getCollection('solaranlagen');
const anlagen = alleAnlagen.sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
const gradients = ['bg-gradient-1', 'bg-gradient-2', 'bg-gradient-3'];
const icons: Record<string, string> = { Schulanlage: '🏫', Privathaus: '🏠' };
---
<BaseLayout title="Solaranlagen" description="Unsere Solaranlagen in Bonstetten – Schulhaus Schachenmatten 2 & 4 sowie Chapfstrasse 31.">

  <!-- Page Header -->
  <div class="page-hero">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Unsere Anlagen</span>
      <h1>Solaranlagen in Bonstetten</h1>
      <p class="lead">
        Drei Photovoltaikanlagen, vollständig durch private Darlehen finanziert –
        zusammen produzieren sie jährlich rund <strong>95'000 kWh</strong> sauberen Strom.
      </p>
      <!-- Summary stats -->
      <div class="summary-stats">
        <div class="stat-item">
          <span class="stat-value">104 kWp</span>
          <span class="stat-label">Gesamtleistung</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value">~95'000 kWh</span>
          <span class="stat-label">Jahresertrag</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value">3 Anlagen</span>
          <span class="stat-label">In Betrieb</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Anlagen -->
  <section class="section">
    <div class="container">
      <div class="anlagen-list">
        {await Promise.all(anlagen.map(async (anlage, i) => {
          const { Content } = await render(anlage);
          const icon = icons[anlage.data.badge] ?? '⚡';
          return (
            <article class="anlage-card">
              <div class={`anlage-header ${gradients[i % 3]}`}>
                <span class="anlage-icon">{icon}</span>
                <div>
                  <span class="anlage-badge">{anlage.data.badge}</span>
                  <h2 class="anlage-title">{anlage.data.title}</h2>
                </div>
              </div>

              <div class="anlage-body">
                <div class="specs-grid">
                  <div class="spec-block">
                    <span class="spec-label">Leistung</span>
                    <span class="spec-value highlight">{anlage.data.leistung}</span>
                  </div>
                  <div class="spec-block">
                    <span class="spec-label">Jahresertrag</span>
                    <span class="spec-value highlight">{anlage.data.jahresertrag}</span>
                  </div>
                  <div class="spec-block">
                    <span class="spec-label">Ausrichtung</span>
                    <span class="spec-value">{anlage.data.ausrichtung}</span>
                  </div>
                  <div class="spec-block">
                    <span class="spec-label">Anlagetyp</span>
                    <span class="spec-value">{anlage.data.typ}</span>
                  </div>
                  <div class="spec-block">
                    <span class="spec-label">Module</span>
                    <span class="spec-value">{anlage.data.module}</span>
                  </div>
                  <div class="spec-block">
                    <span class="spec-label">Finanzierung</span>
                    <span class="spec-value">{anlage.data.finanzierung}</span>
                  </div>
                  {anlage.data.umsetzungspartner && (
                    <div class="spec-block">
                      <span class="spec-label">Umsetzungspartner</span>
                      <span class="spec-value">{anlage.data.umsetzungspartner}</span>
                    </div>
                  )}
                </div>

                <!-- Markdown-Body (z.B. Messdaten-Tabelle) -->
                <div class="article-body">
                  <Content />
                </div>

                <div class="anlage-footer">
                  {anlage.data.monitoring_url ? (
                    <a href={anlage.data.monitoring_url} target="_blank" rel="noopener" class="btn btn-primary monitoring-btn">
                      📊 Live-Monitoring →
                    </a>
                  ) : (
                    <span class="no-monitoring">Kein Live-Monitoring verfügbar</span>
                  )}
                </div>
              </div>
            </article>
          );
        }))}
      </div>
    </div>
  </section>

  <!-- Mitmachen CTA -->
  <section class="section bg-light">
    <div class="container text-center">
      <h2>Interessiert an einer eigenen Anlage?</h2>
      <p class="lead" style="max-width: 600px; margin: 0 auto 2rem;">
        Der Verein solarbonstetten unterstützt Hauseigentümer bei der Planung und Finanzierung
        von Solaranlagen – durch Beratung und private Darlehen aus der Gemeinschaft.
      </p>
      <a href="mailto:info@solarbonstetten.ch" class="btn btn-primary">Kontakt aufnehmen</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    position: relative;
    padding: 11rem 0 5rem;
    overflow: hidden;
  }
  .page-hero .badge { margin-bottom: 1rem; }
  .page-hero h1 { font-size: 2.75rem; margin-bottom: 1rem; }
  .page-hero .lead { font-size: 1.125rem; color: var(--color-text-light); max-width: 620px; margin-bottom: 2.5rem; }

  /* Summary stats */
  .summary-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .stat-item { display: flex; flex-direction: column; }
  .stat-value { font-size: 1.75rem; font-weight: 700; color: var(--color-secondary); }
  .stat-label { font-size: 0.875rem; color: var(--color-text-light); margin-top: 0.25rem; }
  .stat-divider { width: 1px; height: 40px; background: #e2e8f0; }

  /* Anlagen list */
  .anlagen-list { display: flex; flex-direction: column; gap: 2.5rem; }

  /* Anlage card */
  .anlage-card {
    background: var(--color-background);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    border: 1px solid #f1f5f9;
  }
  .anlage-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 2.5rem;
  }
  .anlage-icon { font-size: 2.5rem; }
  .anlage-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }
  .anlage-title { font-size: 1.5rem; margin: 0; }

  /* Specs */
  .anlage-body { padding: 2.5rem; }
  .specs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 2rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #f1f5f9;
  }
  .spec-block { display: flex; flex-direction: column; gap: 0.25rem; }
  .spec-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-light); }
  .spec-value { font-size: 1rem; color: var(--color-secondary); font-weight: 500; }
  .spec-value.highlight { font-size: 1.2rem; font-weight: 700; color: var(--color-primary-dark); }

  /* Messdaten */
  .messdaten { margin-bottom: 2rem; }
  .messdaten h3 { font-size: 1rem; color: var(--color-text-light); font-weight: 600; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .messdaten-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    background: var(--color-bg-light);
    border-radius: var(--border-radius);
    padding: 1.5rem;
  }
  .messdaten-item { display: flex; flex-direction: column; gap: 0.25rem; }
  .messdaten-value { font-size: 1.1rem; font-weight: 700; color: var(--color-secondary); }
  .messdaten-label { font-size: 0.8rem; color: var(--color-text-light); }

  /* Footer */
  .anlage-footer { display: flex; align-items: center; gap: 1rem; }
  .monitoring-btn { font-size: 0.95rem; }
  .no-monitoring { font-size: 0.9rem; color: var(--color-text-light); font-style: italic; }

  /* Responsive */
  @media (max-width: 768px) {
    .specs-grid { grid-template-columns: repeat(2, 1fr); }
    .messdaten-grid { grid-template-columns: repeat(2, 1fr); }
    .anlage-body { padding: 1.5rem; }
    .anlage-header { padding: 1.5rem; }
    .summary-stats { gap: 1.25rem; }
    .stat-divider { display: none; }
  }
  @media (max-width: 480px) {
    .specs-grid { grid-template-columns: 1fr; }
    .messdaten-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
