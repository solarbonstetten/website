---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const anlagen = [
  {
    id: 'schachenmatten-2',
    name: 'Schulhaus Schachenmatten 2',
    badge: 'Schulanlage',
    finanzierung: 'Vollständig durch private Darlehen',
    typ: 'Schrägdach-PV-Anlage',
    ausrichtung: 'Ost-Ost-Süd',
    leistung: '28.08 kWp',
    jahresertrag: '~25\'000 kWh',
    module: '260 Wp, monokristallin (Deutschland)',
    monitoring: 'http://solarspar.solarlog-web.ch/33238.html?c=',
    gradient: 'bg-gradient-1',
    icon: '🏫',
  },
  {
    id: 'schachenmatten-4',
    name: 'Schulhaus Schachenmatten 4',
    badge: 'Schulanlage',
    finanzierung: 'Vollständig durch private Darlehen',
    typ: 'Flachdach-PV-Anlage (aufgeständert)',
    ausrichtung: 'Süd',
    leistung: '45.76 kWp',
    jahresertrag: '~41\'000 kWh',
    module: '260 Wp, monokristallin',
    monitoring: 'http://solarspar.solarlog-web.ch/31567.html',
    gradient: 'bg-gradient-2',
    icon: '🏫',
  },
  {
    id: 'chapfstrasse',
    name: 'Chapfstrasse 31, Bonstetten',
    badge: 'Privathaus',
    finanzierung: 'Durch private Darlehen',
    typ: 'Schrägdach-PV-Anlage (beidseitig)',
    ausrichtung: 'Südost / Nordwest',
    leistung: '30.40 kWp (16.80 + 13.60)',
    jahresertrag: '~29\'300 kWh',
    module: '78 bifaziale Glas-Glas-Module, 400 Wp (Megasol)',
    monitoring: null,
    gradient: 'bg-gradient-3',
    icon: '🏠',
  },
];
---
<BaseLayout title="Solaranlagen" description="Unsere Solaranlagen in Bonstetten – Schulhaus Schachenmatten 2 & 4 sowie Chapfstrasse 31.">

  <!-- Page Header -->
  <div class="page-hero">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Unsere Anlagen</span>
      <h1>Solaranlagen in Bonstetten</h1>
      <p class="lead">
        Drei Photovoltaikanlagen, vollständig durch private Darlehen finanziert –
        zusammen produzieren sie jährlich rund <strong>95'000 kWh</strong> sauberen Strom.
      </p>
      <!-- Summary stats -->
      <div class="summary-stats">
        <div class="stat-item">
          <span class="stat-value">104 kWp</span>
          <span class="stat-label">Gesamtleistung</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value">~95'000 kWh</span>
          <span class="stat-label">Jahresertrag</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value">3 Anlagen</span>
          <span class="stat-label">In Betrieb</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Anlagen -->
  <section class="section">
    <div class="container">
      <div class="anlagen-list">
        {anlagen.map((anlage, i) => (
          <article class="anlage-card">
            <!-- Farbiger Header-Streifen -->
            <div class={`anlage-header ${anlage.gradient}`}>
              <span class="anlage-icon">{anlage.icon}</span>
              <div>
                <span class="anlage-badge">{anlage.badge}</span>
                <h2 class="anlage-title">{anlage.name}</h2>
              </div>
            </div>

            <div class="anlage-body">
              <!-- Technische Specs -->
              <div class="specs-grid">
                <div class="spec-block">
                  <span class="spec-label">Leistung</span>
                  <span class="spec-value highlight">{anlage.leistung}</span>
                </div>
                <div class="spec-block">
                  <span class="spec-label">Jahresertrag</span>
                  <span class="spec-value highlight">{anlage.jahresertrag}</span>
                </div>
                <div class="spec-block">
                  <span class="spec-label">Ausrichtung</span>
                  <span class="spec-value">{anlage.ausrichtung}</span>
                </div>
                <div class="spec-block">
                  <span class="spec-label">Anlagetyp</span>
                  <span class="spec-value">{anlage.typ}</span>
                </div>
                <div class="spec-block">
                  <span class="spec-label">Module</span>
                  <span class="spec-value">{anlage.module}</span>
                </div>
                <div class="spec-block">
                  <span class="spec-label">Finanzierung</span>
                  <span class="spec-value">{anlage.finanzierung}</span>
                </div>
              </div>

              <!-- Chapfstrasse: Messdaten -->
              {anlage.id === 'chapfstrasse' && (
                <div class="messdaten">
                  <h3>Messdaten Nov 2023 – Nov 2024</h3>
                  <div class="messdaten-grid">
                    <div class="messdaten-item">
                      <span class="messdaten-value">27'682 kWh</span>
                      <span class="messdaten-label">Jahresproduktion</span>
                    </div>
                    <div class="messdaten-item">
                      <span class="messdaten-value">4'386 kWh</span>
                      <span class="messdaten-label">Bester Monat (Juli 2024)</span>
                    </div>
                    <div class="messdaten-item">
                      <span class="messdaten-value">458 kWh</span>
                      <span class="messdaten-label">Schwächster Monat (Dez. 2023)</span>
                    </div>
                    <div class="messdaten-item">
                      <span class="messdaten-value">4'828 kWh</span>
                      <span class="messdaten-label">Eigenverbrauch (~17%)</span>
                    </div>
                  </div>
                </div>
              )}

              <!-- Monitoring Link -->
              <div class="anlage-footer">
                {anlage.monitoring ? (
                  <a href={anlage.monitoring} target="_blank" rel="noopener" class="btn btn-primary monitoring-btn">
                    📊 Live-Monitoring →
                  </a>
                ) : (
                  <span class="no-monitoring">Kein Live-Monitoring verfügbar</span>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Mitmachen CTA -->
  <section class="section bg-light">
    <div class="container text-center">
      <h2>Interessiert an einer eigenen Anlage?</h2>
      <p class="lead" style="max-width: 600px; margin: 0 auto 2rem;">
        Der Verein solarbonstetten unterstützt Hauseigentümer bei der Planung und Finanzierung
        von Solaranlagen – durch Beratung und private Darlehen aus der Gemeinschaft.
      </p>
      <a href="mailto:info@solarbonstetten.ch" class="btn btn-primary">Kontakt aufnehmen</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    position: relative;
    padding: 11rem 0 5rem;
    overflow: hidden;
  }
  .page-hero .badge { margin-bottom: 1rem; }
  .page-hero h1 { font-size: 2.75rem; margin-bottom: 1rem; }
  .page-hero .lead { font-size: 1.125rem; color: var(--color-text-light); max-width: 620px; margin-bottom: 2.5rem; }

  /* Summary stats */
  .summary-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .stat-item { display: flex; flex-direction: column; }
  .stat-value { font-size: 1.75rem; font-weight: 700; color: var(--color-secondary); }
  .stat-label { font-size: 0.875rem; color: var(--color-text-light); margin-top: 0.25rem; }
  .stat-divider { width: 1px; height: 40px; background: #e2e8f0; }

  /* Anlagen list */
  .anlagen-list { display: flex; flex-direction: column; gap: 2.5rem; }

  /* Anlage card */
  .anlage-card {
    background: var(--color-background);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    border: 1px solid #f1f5f9;
  }
  .anlage-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 2.5rem;
  }
  .anlage-icon { font-size: 2.5rem; }
  .anlage-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }
  .anlage-title { font-size: 1.5rem; margin: 0; }

  /* Specs */
  .anlage-body { padding: 2.5rem; }
  .specs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 2rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #f1f5f9;
  }
  .spec-block { display: flex; flex-direction: column; gap: 0.25rem; }
  .spec-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-light); }
  .spec-value { font-size: 1rem; color: var(--color-secondary); font-weight: 500; }
  .spec-value.highlight { font-size: 1.2rem; font-weight: 700; color: var(--color-primary-dark); }

  /* Messdaten */
  .messdaten { margin-bottom: 2rem; }
  .messdaten h3 { font-size: 1rem; color: var(--color-text-light); font-weight: 600; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .messdaten-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    background: var(--color-bg-light);
    border-radius: var(--border-radius);
    padding: 1.5rem;
  }
  .messdaten-item { display: flex; flex-direction: column; gap: 0.25rem; }
  .messdaten-value { font-size: 1.1rem; font-weight: 700; color: var(--color-secondary); }
  .messdaten-label { font-size: 0.8rem; color: var(--color-text-light); }

  /* Footer */
  .anlage-footer { display: flex; align-items: center; gap: 1rem; }
  .monitoring-btn { font-size: 0.95rem; }
  .no-monitoring { font-size: 0.9rem; color: var(--color-text-light); font-style: italic; }

  /* Responsive */
  @media (max-width: 768px) {
    .specs-grid { grid-template-columns: repeat(2, 1fr); }
    .messdaten-grid { grid-template-columns: repeat(2, 1fr); }
    .anlage-body { padding: 1.5rem; }
    .anlage-header { padding: 1.5rem; }
    .summary-stats { gap: 1.25rem; }
    .stat-divider { display: none; }
  }
  @media (max-width: 480px) {
    .specs-grid { grid-template-columns: 1fr; }
    .messdaten-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
