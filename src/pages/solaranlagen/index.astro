---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const alleAnlagen = await getCollection('solaranlagen');
const anlagen = alleAnlagen.sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);
const gradients = [
  'bg-gradient-to-br from-amber-100 to-amber-200',
  'bg-gradient-to-br from-sky-100 to-sky-200',
  'bg-gradient-to-br from-slate-100 to-slate-200',
];
const icons: Record<string, string> = { Schulanlage: '🏫', Privathaus: '🏠' };
---
<BaseLayout title="Solaranlagen" description="Unsere Solaranlagen in Bonstetten – Schulhaus Schachenmatten 2 & 4 sowie Chapfstrasse 31.">

  <!-- Hero -->
  <div class="relative overflow-hidden" style="padding: 11rem 0 5rem">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Unsere Anlagen</span>
      <h1 class="mb-4">Solaranlagen in Bonstetten</h1>
      <p class="text-lg text-slate-500 max-w-2xl leading-relaxed mb-10">
        Drei Photovoltaikanlagen, vollständig durch private Darlehen finanziert –
        zusammen produzieren sie jährlich rund <strong class="text-slate-700">95'000 kWh</strong> sauberen Strom.
      </p>

      <!-- Kennzahlen -->
      <div class="flex items-center gap-8 flex-wrap">
        <div class="flex flex-col">
          <span class="text-3xl font-bold text-slate-900">104 kWp</span>
          <span class="text-sm text-slate-500 mt-1">Gesamtleistung</span>
        </div>
        <div class="w-px h-10 bg-slate-200 max-sm:hidden"></div>
        <div class="flex flex-col">
          <span class="text-3xl font-bold text-slate-900">~95'000 kWh</span>
          <span class="text-sm text-slate-500 mt-1">Jahresertrag</span>
        </div>
        <div class="w-px h-10 bg-slate-200 max-sm:hidden"></div>
        <div class="flex flex-col">
          <span class="text-3xl font-bold text-slate-900">3 Anlagen</span>
          <span class="text-sm text-slate-500 mt-1">In Betrieb</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Anlagen -->
  <section class="section">
    <div class="container">
      <div class="flex flex-col gap-10">
        {await Promise.all(anlagen.map(async (anlage, i) => {
          const { Content } = await render(anlage);
          const icon = icons[anlage.data.badge] ?? '⚡';
          return (
            <article id={anlage.id} class="bg-white rounded-2xl shadow-md overflow-hidden border border-slate-100 scroll-mt-28">

              <!-- Header mit Gradient -->
              <div class={`flex items-center gap-6 px-10 py-8 ${gradients[i % 3]}`}>
                <span class="text-4xl">{icon}</span>
                <div>
                  <span class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-1 block">{anlage.data.badge}</span>
                  <h2 class="text-2xl font-bold m-0">{anlage.data.title}</h2>
                </div>
              </div>

              <!-- Körper -->
              <div class="px-10 py-10 max-sm:px-6 max-sm:py-6">

                <!-- Technische Daten -->
                <div class="grid grid-cols-3 md:grid-cols-2 gap-x-8 gap-y-6 mb-8 pb-8 border-b border-slate-100 max-sm:grid-cols-1">
                  <div class="flex flex-col gap-1">
                    <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Leistung</span>
                    <span class="text-xl font-bold text-amber-700">{anlage.data.leistung}</span>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Jahresertrag</span>
                    <span class="text-xl font-bold text-amber-700">{anlage.data.jahresertrag}</span>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Ausrichtung</span>
                    <span class="text-base font-medium text-slate-900">{anlage.data.ausrichtung}</span>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Anlagetyp</span>
                    <span class="text-base font-medium text-slate-900">{anlage.data.typ}</span>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Module</span>
                    <span class="text-base font-medium text-slate-900">{anlage.data.module}</span>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Finanzierung</span>
                    <span class="text-base font-medium text-slate-900">{anlage.data.finanzierung}</span>
                  </div>
                  {anlage.data.umsetzungspartner && (
                    <div class="flex flex-col gap-1">
                      <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Umsetzungspartner</span>
                      <span class="text-base font-medium text-slate-900">{anlage.data.umsetzungspartner}</span>
                    </div>
                  )}
                </div>

                <!-- Markdown-Inhalt (Messdaten-Tabelle etc.) -->
                <div class="article-body">
                  <Content />
                </div>

                <!-- Footer -->
                <div class="flex items-center gap-4 mt-6">
                  {anlage.data.monitoring_url ? (
                    <a href={anlage.data.monitoring_url} target="_blank" rel="noopener" class="btn btn-primary">
                      📊 Live-Monitoring →
                    </a>
                  ) : (
                    <span class="text-sm text-slate-400 italic">Kein Live-Monitoring verfügbar</span>
                  )}
                </div>

              </div>
            </article>
          );
        }))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-slate-50">
    <div class="container text-center">
      <h2 class="mb-4">Interessiert an einer eigenen Anlage?</h2>
      <p class="text-lg text-slate-500 max-w-xl mx-auto mb-8">
        Der Verein solarbonstetten unterstützt Hauseigentümer bei der Planung und Finanzierung
        von Solaranlagen – durch Beratung und private Darlehen aus der Gemeinschaft.
      </p>
      <a href="mailto:info@solarbonstetten.ch" class="btn btn-primary">Kontakt aufnehmen</a>
    </div>
  </section>

</BaseLayout>
