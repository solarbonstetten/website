---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('statuten');
const statuten = entries[0];
const { Content } = await render(statuten);
---
<BaseLayout title="Statuten" description="Vereinsstatuten des Vereins solarbonstetten, gegründet am 1. Oktober 2011 in Bonstetten ZH.">

  <div class="page-hero">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Der Verein</span>
      <h1>{statuten.data.title}</h1>
      <p class="lead">Angenommen an der Gründungsversammlung vom 1. Oktober 2011.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="statuten-content">
        <div class="statuten-meta">
          <span>📄 Stand: {statuten.data.stand}</span>
          <a
            href="https://files.wbk.kreativmedia.ch/43/10/431078b2-e441-47e7-85d7-b56988acfd00.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline-sm"
          >
            PDF herunterladen ↓
          </a>
        </div>
        <div class="statuten-body">
          <Content />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding: 11rem 0 5rem;
    overflow: hidden;
  }
  .page-hero h1 { font-size: 2.75rem; margin-bottom: 1rem; }
  .page-hero .lead { font-size: 1.125rem; color: var(--color-text-light); max-width: 560px; }

  .statuten-content { max-width: 760px; margin: 0 auto; }

  .statuten-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1rem 1.25rem;
    background: #f8fafc;
    border-radius: var(--border-radius);
    border-left: 3px solid var(--color-primary);
    margin-bottom: 2.5rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }
  .btn-outline-sm {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    transition: var(--transition);
  }
  .btn-outline-sm:hover {
    background: var(--color-primary);
    color: #fff;
  }

  .statuten-body :global(h2) {
    font-size: 1.2rem;
    color: var(--color-secondary);
    margin: 2.25rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }
  .statuten-body :global(p),
  .statuten-body :global(li) {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 0.6rem;
  }
  .statuten-body :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .statuten-body :global(strong) { color: var(--color-secondary); }
  .statuten-body :global(hr) {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2rem 0;
  }
</style>
