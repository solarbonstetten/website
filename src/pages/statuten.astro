---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('statuten');
const statuten = entries[0];
const { Content } = await render(statuten);
---
<BaseLayout title="Statuten" description="Vereinsstatuten des Vereins solarbonstetten, gegründet am 1. Oktober 2011 in Bonstetten ZH.">

  <!-- Hero -->
  <div class="relative overflow-hidden" style="padding: 11rem 0 5rem">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Der Verein</span>
      <h1 class="mb-4">{statuten.data.title}</h1>
      <p class="text-lg text-slate-500 max-w-xl leading-relaxed">
        Angenommen an der Gründungsversammlung vom 1. Oktober 2011.
      </p>
    </div>
  </div>

  <!-- Inhalt -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">

        <!-- Meta-Bar -->
        <div class="flex items-center justify-between gap-4 flex-wrap bg-slate-50 border-l-4 border-amber-400 rounded-r-xl px-5 py-4 mb-10 text-sm text-slate-500">
          <span>📄 Stand: {statuten.data.stand}</span>
          <a
            href="/dokumente/vereinsstatuten.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-amber-700 border border-amber-700 px-3 py-1 rounded-full hover:bg-amber-700 hover:text-white transition-colors"
          >
            PDF herunterladen ↓
          </a>
        </div>

        <!-- Markdown-Inhalt -->
        <div class="statuten-body">
          <Content />
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Scoped styles für gerenderten Markdown-Inhalt */
  .statuten-body :global(h2) {
    font-size: 1.2rem;
    color: var(--color-secondary);
    margin: 2.25rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }
  .statuten-body :global(p),
  .statuten-body :global(li) {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 0.6rem;
  }
  .statuten-body :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .statuten-body :global(strong) { color: var(--color-secondary); }
  .statuten-body :global(hr) {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2rem 0;
  }
</style>
