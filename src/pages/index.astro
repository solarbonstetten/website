---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const latestNews = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const latestProjekte = (await getCollection('projekte')).slice(0, 3);
const gradients = ['bg-gradient-1', 'bg-gradient-2', 'bg-gradient-3'];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Erneuerbare Energien lokal">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-text">
        <span class="badge">14 Jahre solarbonstetten!</span>
        <h1 class="fade-in-up">Solarenergie und Erneuerbare Energien in Bonstetten.</h1>
        <p class="fade-in-up delay-1">Wir setzen uns dafür ein, mit Hilfe Privater die Mittel zur Verfügung zu stellen, um grosse Solaranlagen in Bonstetten zu bauen und lokal produzierten Strom im Dorf zu verkaufen.</p>
        <div class="hero-actions fade-in-up delay-2">
          <a href="#verein" class="btn btn-primary">Mitmachen</a>
          <a href="#aktuell" class="btn btn-secondary">Mehr erfahren</a>
        </div>
      </div>
      <div class="hero-image-wrap fade-in-up delay-3">
        <svg viewBox="0 0 500 450" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;">
          <line x1="50" y1="380" x2="450" y2="380" stroke="#94a3b8" stroke-width="3" stroke-linecap="round"/>
          <rect x="150" y="200" width="200" height="180" fill="#f8fafc" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <polygon points="120,200 250,110 380,200" fill="#f8fafc" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <rect x="230" y="300" width="40" height="80" fill="none" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <circle cx="262" cy="345" r="3" fill="#0f172a"/>
          <rect x="175" y="240" width="35" height="40" fill="none" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <line x1="192.5" y1="240" x2="192.5" y2="280" stroke="#0f172a" stroke-width="2"/>
          <line x1="175" y1="260" x2="210" y2="260" stroke="#0f172a" stroke-width="2"/>
          <rect x="290" y="240" width="35" height="40" fill="none" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <line x1="307.5" y1="240" x2="307.5" y2="280" stroke="#0f172a" stroke-width="2"/>
          <line x1="290" y1="260" x2="325" y2="260" stroke="#0f172a" stroke-width="2"/>
          <circle cx="400" cy="90" r="28" fill="none" stroke="#f59e0b" stroke-width="3" stroke-dasharray="6 6"/>
          <circle cx="400" cy="90" r="14" fill="#f59e0b"/>
          <polygon points="145,183 220,131 235,148 160,200" fill="#f59e0b" stroke="#f59e0b" stroke-width="2" stroke-linejoin="round"/>
          <line x1="182.5" y1="157" x2="197.5" y2="174" stroke="#ffffff" stroke-width="1.5" opacity="0.6"/>
          <line x1="168" y1="191" x2="227" y2="140" stroke="#ffffff" stroke-width="1.5" opacity="0.6"/>
          <rect x="100" y="330" width="30" height="50" rx="4" fill="#e2e8f0" stroke="#0f172a" stroke-width="4"/>
          <rect x="106" y="355" width="18" height="20" fill="#f59e0b" rx="2"/>
          <line x1="115" y1="340" x2="115" y2="345" stroke="#0f172a" stroke-width="3" stroke-linecap="round"/>
          <path d="M 152 195 L 115 220 L 115 330" fill="none" stroke="#f59e0b" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="glass-card widget-card">
          <div class="widget-icon">☀️</div>
          <div class="widget-data">
            <h3>1.68 GWh</h3>
            <p>Lokal produzierter Strom im Jahr</p>
          </div>
        </div>
        <div class="glass-card widget-card widget-2">
          <div class="widget-icon">⚡</div>
          <div class="widget-data">
            <h3>116 Anlagen</h3>
            <p>PV-Anlagen in Bonstetten installiert</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Aktuelles -->
  <section id="aktuell" class="section bg-light">
    <div class="container">
      <div class="section-header text-center">
        <h2>Aktuelles & News</h2>
        <p>Was uns aktuell bewegt und beschäftigt</p>
      </div>
      {latestNews.length === 0 ? (
        <p class="text-center">Noch keine News vorhanden.</p>
      ) : (
        <div class="grid-3">
          {latestNews.map((article, i) => (
            <article class="news-card">
              <div class={`card-image ${gradients[i % 3]}`}></div>
              <div class="card-content">
                <span class="news-date">{article.data.date.toLocaleDateString('de-CH', { month: 'long', year: 'numeric' })}</span>
                <h3>{article.data.title}</h3>
                <a href={`${base}/news/${article.id}`} class="read-more">Artikel lesen →</a>
              </div>
            </article>
          ))}
        </div>
      )}
      <div class="text-center mt-2">
        <a href={`${base}/news`} class="btn btn-secondary">Alle News</a>
      </div>
    </div>
  </section>

  <!-- Der Verein -->
  <section id="verein" class="section">
    <div class="container split-layout">
      <div class="split-image-container">
        <div class="floating-box-image">
          <h2>Gemeinsam für die Zukunft</h2>
          <p>Lokales Partnerschaftsmodell engagierter Bürger.</p>
        </div>
        <div class="abstract-visual"></div>
      </div>
      <div class="split-text">
        <h2 class="section-title">Der Verein</h2>
        <p class="lead">Der Verein solarbonstetten ist nicht gewinnorientiert. Wir sind ein lokal verankerter Verein, wo Persönlichkeiten aus Bonstetten sich ehrenamtlich für eine ökologische Entwicklung engagieren.</p>
        <ul class="feature-list">
          <li>
            <div class="list-icon">✓</div>
            <div>
              <h4>Vermittlung von Dachflächen</h4>
              <p>Wir finden geeignete Standorte in Bonstetten für grosse Solaranlagen.</p>
            </div>
          </li>
          <li>
            <div class="list-icon">✓</div>
            <div>
              <h4>Vermittlung von Stromabnehmern</h4>
              <p>Abnehmer aus der Gemeinde Bonstetten profitieren vom lokal erzeugten Strom.</p>
            </div>
          </li>
          <li>
            <div class="list-icon">✓</div>
            <div>
              <h4>Zusammenarbeit mit Profis</h4>
              <p>Professionelle Umsetzung dank unserem erfahrenen Partner Solarspar ohne Subventionsabhängigkeit.</p>
            </div>
          </li>
        </ul>
        <a href={`${base}/mitmachen`} class="btn btn-primary mt-2">Jetzt Mitglied werden</a>
      </div>
    </div>
  </section>

  <!-- Projekte -->
  {latestProjekte.length > 0 && (
    <section id="solaranlagen" class="section bg-light">
      <div class="container">
        <div class="section-header text-center">
          <h2>Unsere Projekte</h2>
          <p>Solaranlagen in Bonstetten</p>
        </div>
        <div class="grid-3">
          {latestProjekte.map((projekt, i) => (
            <article class="news-card">
              <div class={`card-image ${gradients[i % 3]}`}></div>
              <div class="card-content">
                <h3>{projekt.data.title}</h3>
                <a href={`${base}/projekte/${projekt.id}`} class="read-more">Mehr erfahren →</a>
              </div>
            </article>
          ))}
        </div>
        <div class="text-center mt-2">
          <a href={`${base}/projekte`} class="btn btn-secondary">Alle Projekte</a>
        </div>
      </div>
    </section>
  )}

</BaseLayout>
