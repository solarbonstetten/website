---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const latestNews = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const latestProjekte = (await getCollection('projekte')).slice(0, 3);
const gradients = [
  'bg-gradient-to-br from-amber-100 to-amber-200',
  'bg-gradient-to-br from-sky-100 to-sky-200',
  'bg-gradient-to-br from-slate-100 to-slate-200',
];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Erneuerbare Energien lokal">

  <!-- Hero -->
  <section class="relative overflow-hidden" style="padding: 12rem 0 8rem">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-16 items-center">

      <!-- Text -->
      <div>
        <span class="badge">14 Jahre solarbonstetten!</span>
        <h1 class="fade-in-up mb-6">Solarenergie und Erneuerbare Energien in Bonstetten.</h1>
        <p class="fade-in-up delay-1 text-lg text-slate-500 leading-relaxed mb-10 max-w-[480px] mx-auto lg:mx-0">
          Wir setzen uns dafür ein, mit Hilfe Privater die Mittel zur Verfügung zu stellen, um grosse Solaranlagen in Bonstetten zu bauen und lokal produzierten Strom im Dorf zu verkaufen.
        </p>
        <div class="fade-in-up delay-2 flex gap-4 justify-center lg:justify-start flex-wrap">
          <a href="#verein" class="btn btn-primary">Mitmachen</a>
          <a href="#aktuell" class="btn btn-secondary">Mehr erfahren</a>
        </div>
      </div>

      <!-- SVG + Widgets -->
      <div class="fade-in-up delay-3 relative h-[400px]">
        <svg viewBox="0 0 500 450" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;">
          <line x1="50" y1="380" x2="450" y2="380" stroke="#94a3b8" stroke-width="3" stroke-linecap="round"/>
          <rect x="150" y="200" width="200" height="180" fill="#f8fafc" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <polygon points="120,200 250,110 380,200" fill="#f8fafc" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <rect x="230" y="300" width="40" height="80" fill="none" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <circle cx="262" cy="345" r="3" fill="#0f172a"/>
          <rect x="175" y="240" width="35" height="40" fill="none" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <line x1="192.5" y1="240" x2="192.5" y2="280" stroke="#0f172a" stroke-width="2"/>
          <line x1="175" y1="260" x2="210" y2="260" stroke="#0f172a" stroke-width="2"/>
          <rect x="290" y="240" width="35" height="40" fill="none" stroke="#0f172a" stroke-width="4" stroke-linejoin="round"/>
          <line x1="307.5" y1="240" x2="307.5" y2="280" stroke="#0f172a" stroke-width="2"/>
          <line x1="290" y1="260" x2="325" y2="260" stroke="#0f172a" stroke-width="2"/>
          <circle cx="400" cy="90" r="28" fill="none" stroke="#f59e0b" stroke-width="3" stroke-dasharray="6 6"/>
          <circle cx="400" cy="90" r="14" fill="#f59e0b"/>
          <polygon points="145,183 220,131 235,148 160,200" fill="#f59e0b" stroke="#f59e0b" stroke-width="2" stroke-linejoin="round"/>
          <line x1="182.5" y1="157" x2="197.5" y2="174" stroke="#ffffff" stroke-width="1.5" opacity="0.6"/>
          <line x1="168" y1="191" x2="227" y2="140" stroke="#ffffff" stroke-width="1.5" opacity="0.6"/>
          <rect x="100" y="330" width="30" height="50" rx="4" fill="#e2e8f0" stroke="#0f172a" stroke-width="4"/>
          <rect x="106" y="355" width="18" height="20" fill="#f59e0b" rx="2"/>
          <line x1="115" y1="340" x2="115" y2="345" stroke="#0f172a" stroke-width="3" stroke-linecap="round"/>
          <path d="M 152 195 L 115 220 L 115 330" fill="none" stroke="#f59e0b" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="glass-card widget-card">
          <div class="widget-icon">☀️</div>
          <div class="widget-data">
            <h3 class="text-xl font-bold">1.68 GWh</h3>
            <p class="text-sm text-slate-500">Lokal produzierter Strom im Jahr</p>
          </div>
        </div>
        <div class="glass-card widget-card widget-2">
          <div class="widget-icon">⚡</div>
          <div class="widget-data">
            <h3 class="text-xl font-bold">116 Anlagen</h3>
            <p class="text-sm text-slate-500">PV-Anlagen in Bonstetten installiert</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Aktuelles -->
  <section id="aktuell" class="section bg-slate-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="mb-4">Aktuelles & News</h2>
        <p class="text-lg text-slate-500">Was uns aktuell bewegt und beschäftigt</p>
      </div>
      {latestNews.length === 0 ? (
        <p class="text-center text-slate-500">Noch keine News vorhanden.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {latestNews.map((article, i) => (
            <article class="news-card bg-white rounded-xl overflow-hidden shadow-sm border border-slate-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-md flex flex-col">
              <div class={`h-[200px] w-full overflow-hidden hidden sm:block ${!article.data.image ? gradients[i % 3] : ''}`}>
                {article.data.image && (
                  <img src={article.data.image} alt={article.data.title} loading="lazy" class="w-full h-full object-cover block" />
                )}
              </div>
              <div class="p-8 flex flex-col flex-1 gap-3">
                <span class="text-xs text-amber-700 font-semibold uppercase tracking-wide">
                  {article.data.date.toLocaleDateString('de-CH', { month: 'long', year: 'numeric' })}
                </span>
                <h3 class="text-slate-900 leading-snug">{article.data.title}</h3>
                <a href={`${base}/news/${article.id}`} class="mt-auto pt-2 font-semibold text-sm text-slate-700 hover:text-amber-700 transition-colors">
                  Artikel lesen →
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
      <div class="text-center mt-10">
        <a href={`${base}/news`} class="btn btn-secondary">Alle News</a>
      </div>
    </div>
  </section>

  <!-- Der Verein -->
  <section id="verein" class="section">
    <div class="container grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Visual (links auf Desktop, oben auf Mobile) -->
      <div class="relative min-h-[400px] bg-gradient-to-br from-slate-50 to-slate-200 rounded-2xl overflow-hidden">
        <div class="abstract-visual"></div>
        <div class="floating-box-image">
          <h2 class="text-xl mb-1">Gemeinsam für die Zukunft</h2>
          <p class="text-sm text-slate-500">Lokales Partnerschaftsmodell engagierter Bürger.</p>
        </div>
      </div>

      <!-- Text (rechts auf Desktop) -->
      <div>
        <h2 class="mb-6">Der Verein</h2>
        <p class="text-lg text-slate-500 leading-relaxed mb-8">
          Der Verein solarbonstetten ist nicht gewinnorientiert. Wir sind ein lokal verankerter Verein, wo Persönlichkeiten aus Bonstetten sich ehrenamtlich für eine ökologische Entwicklung engagieren.
        </p>
        <ul class="flex flex-col gap-6 mb-8 list-none p-0">
          <li class="flex gap-4">
            <div class="list-icon">✓</div>
            <div>
              <h4 class="mb-1">Vermittlung von Dachflächen</h4>
              <p class="text-slate-500 text-sm leading-relaxed">Wir finden geeignete Standorte in Bonstetten für grosse Solaranlagen.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="list-icon">✓</div>
            <div>
              <h4 class="mb-1">Vermittlung von Stromabnehmern</h4>
              <p class="text-slate-500 text-sm leading-relaxed">Abnehmer aus der Gemeinde Bonstetten profitieren vom lokal erzeugten Strom.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="list-icon">✓</div>
            <div>
              <h4 class="mb-1">Zusammenarbeit mit Profis</h4>
              <p class="text-slate-500 text-sm leading-relaxed">Professionelle Umsetzung dank unserem erfahrenen Partner Solarspar ohne Subventionsabhängigkeit.</p>
            </div>
          </li>
        </ul>
        <a href={`${base}/mitmachen`} class="btn btn-primary">Jetzt Mitglied werden</a>
      </div>

    </div>
  </section>

  <!-- Projekte -->
  {latestProjekte.length > 0 && (
    <section id="solaranlagen" class="section bg-slate-50">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="mb-4">Unsere Projekte</h2>
          <p class="text-lg text-slate-500">Solaranlagen in Bonstetten</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {latestProjekte.map((projekt, i) => (
            <article class="news-card bg-white rounded-xl overflow-hidden shadow-sm border border-slate-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-md flex flex-col">
              <div class={`h-[200px] w-full hidden sm:block ${gradients[i % 3]}`}></div>
              <div class="p-8 flex flex-col flex-1 gap-3">
                <h3 class="text-slate-900 leading-snug">{projekt.data.title}</h3>
                <a href={`${base}/projekte/${projekt.id}`} class="mt-auto pt-2 font-semibold text-sm text-slate-700 hover:text-amber-700 transition-colors">
                  Mehr erfahren →
                </a>
              </div>
            </article>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href={`${base}/projekte`} class="btn btn-secondary">Alle Projekte</a>
        </div>
      </div>
    </section>
  )}

</BaseLayout>
