---
import BaseLayout from '../../layouts/BaseLayout.astro';

const zonen = [
  { name: 'Dorfstrasse – Chüeweid',        color: '#e6194b', legId: 1  },
  { name: 'Dorfstrasse – im Vorderdorf',   color: '#46f0f0', legId: 7  },
  { name: 'Schule-Breitenacher',           color: '#f58231', legId: 5  },
  { name: 'Im Schachenhof',               color: '#ffe119', legId: 3  },
  { name: 'Chapfstrasse-Friedhofstrasse',  color: '#3cb44b', legId: 2  },
  { name: 'Buechenegg und Wolfen',         color: '#911eb4', legId: 6  },
  { name: 'Lochenweiher',                  color: '#e6beff', legId: 12 },
  { name: 'Ligusterweg',                   color: '#bcf60c', legId: 9  },
  { name: 'Heumoos',                       color: '#008080', legId: 11 },
  { name: 'Bruggematt',                    color: '#4363d8', legId: 4  },
  { name: 'Lätten',                        color: '#fabebe', legId: 10 },
  { name: 'Lüttenberg',                    color: '#f032e6', legId: 8  },
  { name: 'Stockenweg',                    color: '#9a6324', legId: 13 },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="Lokale Elektrizitäts­gemeinschaft (LEG)"
  description="Solarbonstetten verwaltet die Lokalen Elektrizitätsgemeinschaften in Bonstetten. Strom aus der Nachbarschaft – günstig und lokal."
>

  <!-- Hero -->
  <div class="relative overflow-hidden" style="padding: 11rem 0 5rem">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-16 items-center">
      <div>
        <span class="badge">Lokale Elektrizitäts­gemeinschaft</span>
        <h1 class="mb-6">Strom aus der Nachbarschaft</h1>
        <p class="text-lg text-slate-500 max-w-xl leading-relaxed mb-8">
          Seit Januar 2026 ermöglicht das Schweizer Recht lokale Elektrizitätsgemeinschaften (LEG):
          Solar­strom direkt zwischen Produzierenden und Konsumierenden im gleichen Quartier tauschen –
          günstiger und nachhaltiger als je zuvor.
        </p>
        <a href={`${base}/leg/anmeldung`} class="btn btn-primary">Jetzt anmelden →</a>
      </div>

      <!-- Kennzahlen-Card -->
      <div class="glass-card p-8 rounded-2xl flex flex-col gap-6">
        <div class="flex items-start gap-4">
          <span class="text-3xl">⚡</span>
          <div>
            <p class="font-bold text-slate-900 mb-1">Günstiger Strom</p>
            <p class="text-sm text-slate-500 leading-relaxed">Konsumenten zahlen 20.31 Rp./kWh – deutlich unter dem normalen Tarif.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-3xl">🌞</span>
          <div>
            <p class="font-bold text-slate-900 mb-1">Bessere Vergütung</p>
            <p class="text-sm text-slate-500 leading-relaxed">Produzenten erhalten 12 Rp./kWh – mehr als die übliche Einspeisung ins Netz.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-3xl">🏘️</span>
          <div>
            <p class="font-bold text-slate-900 mb-1">Lokal &amp; direkt</p>
            <p class="text-sm text-slate-500 leading-relaxed">Strom bleibt in Bonstetten – kein langer Transport, maximale lokale Wertschöpfung.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Adress-Lookup -->
  <section class="section">
    <div class="container max-w-2xl">
      <div class="text-center mb-8">
        <span class="badge mb-4 inline-block">Schnellcheck</span>
        <h2 class="mb-3">Finde deine LEG-Zone</h2>
        <p class="text-slate-500 leading-relaxed">Gib deine Adresse ein und sieh sofort, in welcher Zone du bist.</p>
      </div>
      <div class="relative" id="lookup-wrapper">
        <input
          type="search"
          id="addr-search"
          placeholder="z. B. Dorfstrasse 24…"
          autocomplete="off"
          class="addr-input w-full px-5 py-4 text-base border-2 border-slate-200 rounded-2xl focus:outline-none focus:border-amber-400 focus:shadow-[0_0_0_3px_rgba(251,168,3,0.15)] transition-all"
        />
        <!-- Dropdown -->
        <ul id="addr-dropdown" class="hidden absolute z-50 mt-1 w-full bg-white border border-slate-200 rounded-2xl shadow-lg overflow-hidden max-h-72 overflow-y-auto"></ul>
        <!-- Ergebnis -->
        <div id="addr-result" class="hidden mt-4"></div>
      </div>
    </div>
  </section>

  <!-- Was ist eine LEG? -->
  <section class="section bg-slate-50">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="badge mb-4 inline-block">Hintergrund</span>
          <h2 class="mb-6">Was ist eine LEG?</h2>
          <p class="text-slate-500 leading-relaxed mb-4">
            Eine Lokale Elektrizitäts­gemeinschaft (LEG) verbindet Solar-Produzenten und Strom-Konsumenten
            im selben Quartier. Alle Teilnehmenden sind am gleichen Transformatoren­station angeschlossen
            und tauschen Strom direkt untereinander aus – vermittelt durch den Netzbetreiber EKZ.
          </p>
          <p class="text-slate-500 leading-relaxed mb-4">
            Verein solarbonstetten übernimmt die Verwaltung der LEGs in Bonstetten: Wir koordinieren
            die Anmeldungen, vertreten die Gemeinschaft gegenüber EKZ und kümmern uns um die jährliche Abrechnung.
          </p>
          <p class="text-slate-500 leading-relaxed">
            Es sind bis zu <strong class="text-slate-700">13 LEGs</strong> in Bonstetten geplant.
            Jede LEG wird gegründet, sobald sich genug Interessentinnen und Interessenten aus dem jeweiligen Quartier angemeldet haben.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
            <h3 class="text-base font-bold text-slate-900 mb-3">Für Konsumentinnen &amp; Konsumenten</h3>
            <ul class="flex flex-col gap-2 text-sm text-slate-500">
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> Günstigerer Strom (20.31 Rp./kWh)</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> Restliche Energie weiterhin via EKZ geliefert</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> Kein Zusatzaufwand – jährliche Abrechnung</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> Austritt mit 2 Monaten Frist jederzeit möglich</li>
            </ul>
          </div>
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
            <h3 class="text-base font-bold text-slate-900 mb-3">Für Produzentinnen &amp; Produzenten</h3>
            <ul class="flex flex-col gap-2 text-sm text-slate-500">
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> Höhere Vergütung (12 Rp./kWh)</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> Direkter Verkauf im Quartier statt Einspeisung</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> 40% Rabatt auf Netzkosten im Verteilnetz</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 font-bold shrink-0">✓</span> Verwaltung durch solarbonstetten</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- So funktioniert's -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-14">
        <h2 class="mb-4">So funktioniert die Teilnahme</h2>
        <p class="text-lg text-slate-500 max-w-xl mx-auto">In drei Schritten zur lokalen Strom­gemeinschaft.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { nr: '1', titel: 'Interessieren &amp; Anmelden', text: 'Formular ausfüllen und Interesse bekunden. Je mehr Interessierte, desto schneller kann die LEG in deinem Quartier gegründet werden.' },
          { nr: '2', titel: 'LEG wird gegründet', text: 'Sobald sich genug Teilnehmende aus dem gleichen Trafokreis gemeldet haben, gründen wir die LEG und registrieren sie im EKZ-Portal.' },
          { nr: '3', titel: 'Strom tauschen &amp; profitieren', text: 'Ab Aktivierung fliesst lokaler Solarstrom direkt zu dir. Die Abrechnung erfolgt jährlich – automatisch durch solarbonstetten.' },
        ].map(s => (
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8 flex flex-col gap-4">
            <span class="w-12 h-12 bg-amber-400 text-white font-bold text-xl rounded-full flex items-center justify-center">{s.nr}</span>
            <h3 class="text-base font-bold text-slate-900" set:html={s.titel} />
            <p class="text-sm text-slate-500 leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 13 LEG-Zonen -->
  <section class="section bg-slate-50 scroll-mt-20" id="leg-zonen">
    <div class="container">
      <div class="text-center mb-14">
        <span class="badge mb-4 inline-block">Bonstetten</span>
        <h2 class="mb-4">Die 13 LEG-Zonen</h2>
        <p class="text-lg text-slate-500 max-w-xl mx-auto">
          Jede Zone entspricht einem Trafokreis. Du kannst dich für die Zone anmelden,
          in der dein Gebäude liegt – oder «Noch nicht sicher» wählen.
        </p>
      </div>
      <!-- Karte -->
      <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-sm mb-8" style="height: 500px;">
        <iframe
          src="/leg/legmap.html"
          width="100%"
          height="100%"
          style="border: none; display: block;"
          title="LEG-Zonen Karte Bonstetten"
        ></iframe>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3" id="zonen-grid">
        {zonen.map((zone, i) => (
          <div
            class="zone-card bg-white rounded-xl border-2 border-slate-100 shadow-sm px-4 py-3 flex items-center gap-3 cursor-pointer transition-all hover:border-slate-300"
            data-leg-id={zone.legId}
            style={`--zone-color: ${zone.color}`}
          >
            <span class="w-7 h-7 font-bold text-xs rounded-full flex items-center justify-center shrink-0 text-white" style={`background:${zone.color}`}>{i + 1}</span>
            <p class="font-semibold text-slate-900 text-sm m-0">{zone.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Voraussetzungen + Bedingungen -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="mb-6">Voraussetzungen</h2>
          <ul class="flex flex-col gap-4">
            {[
              { icon: '📡', titel: 'Kommunikativer Smart Meter', text: 'Dein Stromanschluss benötigt einen intelligenten Zähler, der Daten aktiv an EKZ übermittelt. Falls noch nicht vorhanden, wird er von EKZ installiert – das kann die Aktivierungsfrist auf 3 Monate verlängern.' },
              { icon: '🗺️', titel: 'Gleiche LEG-Zone', text: 'Alle Mitglieder einer LEG müssen in der gleichen Zone liegen – die Zonen entsprechen den Trafokreisen der EKZ und sind auf der Karte oben eingezeichnet.' },
              { icon: '☀️', titel: 'Mindest-Solaranteil', text: 'Die Solarleistung der LEG muss mindestens 5% der Anschlussleistung aller teilnehmenden Verbraucher betragen.' },
              { icon: '📋', titel: 'EKZ-Bedingungen', text: 'Alle Teilnehmenden akzeptieren die Teilnahmebedingungen von EKZ. Du findest sie im untenstehenden Dokument.' },
            ].map(v => (
              <li class="flex items-start gap-4">
                <span class="text-2xl shrink-0">{v.icon}</span>
                <div>
                  <p class="font-semibold text-slate-900 text-sm mb-1">{v.titel}</p>
                  <p class="text-sm text-slate-500 leading-relaxed">{v.text}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="mb-6">Preismodell</h2>
          <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-6">
            <h3 class="text-base font-bold text-slate-900 mb-4">LEG-Strompreise Bonstetten</h3>
            <div class="text-sm">
              <div class="bg-white rounded-xl p-4 text-center">
                <p class="text-xs text-slate-400 uppercase tracking-wider mb-1">Bezugspreis</p>
                <p class="text-2xl font-bold text-amber-700">20.31 Rp.</p>
                <p class="text-xs text-slate-400">pro kWh</p>
              </div>
            </div>
            <p class="text-xs text-slate-500 mt-4 leading-relaxed">
              Produzenten erhalten 12 Rp./kWh. Der Restbedarf wird weiterhin über EKZ zum regulären Tarif geliefert.
            </p>
          </div>
          <div class="bg-white border border-slate-200 rounded-2xl p-6">
            <h3 class="text-base font-bold text-slate-900 mb-2">Ein- &amp; Austritt</h3>
            <p class="text-sm text-slate-500 leading-relaxed">
              Der Eintritt in eine LEG ist nach Aktivierung (ca. 3 Monate nach Gründung) möglich.
              Der Austritt ist mit <strong class="text-slate-700">2 Monaten Frist</strong> auf Monatsende jederzeit möglich.
            </p>
          </div>

          <!-- Dokument -->
          <div class="flex items-center gap-4 bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 mt-4">
            <span class="text-2xl shrink-0">📄</span>
            <div class="flex-1 min-w-0">
              <strong class="block text-sm text-slate-900 mb-0.5">EKZ-Teilnahmebedingungen</strong>
              <p class="text-xs text-slate-500 m-0">Offizielle Bedingungen für die Teilnahme an einer LEG im EKZ-Netz.</p>
            </div>
            <a href="https://www.ekz.ch/dam/ekz/angebote/strom/produzenten-und-gemeinschaften/leg/LEG-Bedingungen-EKZ.pdf"
               target="_blank" rel="noopener noreferrer"
               class="btn btn-outline text-sm shrink-0">PDF ↗</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-amber-400">
    <div class="container text-center">
      <h2 class="mb-4 text-white">Interesse? Jetzt anmelden!</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8 leading-relaxed">
        Melde dich an – sobald sich genug Interessierte in deinem Quartier gefunden haben, gründen wir die LEG.
      </p>
      <a href={`${base}/leg/anmeldung`} class="btn bg-white text-amber-700 hover:bg-amber-50 font-bold px-8 py-4 text-base">
        Zur Anmeldung →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .zone-card.active {
    border-color: var(--zone-color) !important;
    background-color: color-mix(in srgb, var(--zone-color) 10%, white);
  }
</style>

<script define:vars={{ zonen }}>
  const iframe = document.querySelector('iframe[title="LEG-Zonen Karte Bonstetten"]');
  const cards = document.querySelectorAll('.zone-card');

  // Card click → select zone on map
  cards.forEach(card => {
    card.addEventListener('click', () => {
      const legId = parseInt(card.dataset.legId ?? '-1');
      const isAlreadyActive = card.classList.contains('active');

      cards.forEach(c => c.classList.remove('active'));

      if (!isAlreadyActive) {
        card.classList.add('active');
        iframe?.contentWindow?.postMessage({ type: 'selectLeg', legId }, '*');
      } else {
        iframe?.contentWindow?.postMessage({ type: 'selectLeg', legId: -1 }, '*');
      }
    });
  });

  // Map click → highlight matching card
  window.addEventListener('message', (event) => {
    if (event.data?.type !== 'legSelected') return;
    const legId = event.data.legId;
    cards.forEach(card => {
      card.classList.toggle('active', parseInt(card.dataset.legId ?? '-1') === legId && legId !== -1);
    });
    // Scroll active card into view
    const active = document.querySelector('.zone-card.active');
    if (active) active.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  // ── Address-Lookup ──────────────────────────────────────────
  const searchInput = document.getElementById('addr-search');
  const dropdown    = document.getElementById('addr-dropdown');
  const resultBox   = document.getElementById('addr-result');

  let addresses = null; // lazy loaded

  async function loadAddresses() {
    if (addresses) return addresses;
    const res = await fetch('/leg/data/addresses.json');
    addresses = await res.json();
    return addresses;
  }

  function selectAddress(entry) {
    // Close dropdown
    dropdown.innerHTML = '';
    dropdown.classList.add('hidden');
    searchInput.value = entry.address;

    // Lookup zone
    const legId = entry.leg_index !== null ? entry.leg_index + 1 : null;
    const zone  = legId !== null ? zonen.find(z => z.legId === legId) : null;

    // Show result
    if (zone) {
      resultBox.innerHTML = `
        <div class="flex items-center gap-4 bg-white border-2 rounded-2xl px-5 py-4" style="border-color: ${zone.color}">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 text-white font-bold text-sm" style="background:${zone.color}">
            ${zonen.indexOf(zone) + 1}
          </span>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-slate-400 uppercase tracking-wider mb-0.5">Deine LEG-Zone</p>
            <p class="font-bold text-slate-900 text-base m-0">${zone.name}</p>
          </div>
          <a href="#leg-zonen" class="btn btn-outline text-sm shrink-0" id="zone-link">Zur Zone →</a>
        </div>`;
      resultBox.classList.remove('hidden');

      // Highlight zone card
      cards.forEach(c => c.classList.toggle('active', parseInt(c.dataset.legId ?? '-1') === legId));

      // "Zur Zone" button: intercept click to also trigger map zoom after scroll
      document.getElementById('zone-link')?.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('leg-zonen')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(() => {
          iframe?.contentWindow?.postMessage({ type: 'selectLeg', legId }, '*');
        }, 600);
      });

      // Scroll to map section first, then zoom map after scroll animation completes
      document.getElementById('leg-zonen')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setTimeout(() => {
        iframe?.contentWindow?.postMessage({ type: 'selectLeg', legId }, '*');
      }, 600);
    } else {
      resultBox.innerHTML = `
        <div class="flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-slate-500 text-sm">
          <span class="text-xl">🔍</span>
          <span>Diese Adresse liegt nicht in einer der 13 LEG-Zonen in Bonstetten.</span>
        </div>`;
      resultBox.classList.remove('hidden');
      // Reset map + cards
      cards.forEach(c => c.classList.remove('active'));
      iframe?.contentWindow?.postMessage({ type: 'selectLeg', legId: -1 }, '*');
    }
  }

  searchInput?.addEventListener('input', async () => {
    const q = searchInput.value.trim().toLowerCase();
    resultBox.classList.add('hidden');
    resultBox.innerHTML = '';

    if (q.length < 2) {
      dropdown.innerHTML = '';
      dropdown.classList.add('hidden');
      return;
    }

    const data = await loadAddresses();
    const hits = data.filter(e => e.address.toLowerCase().includes(q)).slice(0, 8);

    if (hits.length === 0) {
      dropdown.innerHTML = '';
      dropdown.classList.add('hidden');
      return;
    }

    dropdown.innerHTML = hits.map((e, i) =>
      `<li class="addr-option px-5 py-3 cursor-pointer hover:bg-amber-50 text-sm text-slate-700 border-b border-slate-100 last:border-0" data-idx="${i}">${e.address}</li>`
    ).join('');
    dropdown.classList.remove('hidden');

    dropdown.querySelectorAll('.addr-option').forEach((li, i) => {
      li.addEventListener('click', () => selectAddress(hits[i]));
    });
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    if (!document.getElementById('lookup-wrapper')?.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });

  // Reset when input is cleared
  searchInput?.addEventListener('search', () => {
    if (!searchInput.value) {
      dropdown.classList.add('hidden');
      resultBox.classList.add('hidden');
      cards.forEach(c => c.classList.remove('active'));
      iframe?.contentWindow?.postMessage({ type: 'selectLeg', legId: -1 }, '*');
    }
  });
</script>
