---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const alleLinks = await getCollection('links');

const kategorien = [
  'Behörden & Verbände',
  'Umwelt & Nachhaltigkeit',
  'Energie & Solar',
  'Region & Gemeinde',
];

const kategorieIcons: Record<string, string> = {
  'Behörden & Verbände': '🏛️',
  'Umwelt & Nachhaltigkeit': '🌱',
  'Energie & Solar': '☀️',
  'Region & Gemeinde': '📍',
};

const gruppiertLinks = kategorien.map(kat => ({
  name: kat,
  icon: kategorieIcons[kat],
  links: alleLinks
    .filter(l => l.data.kategorie === kat)
    .sort((a, b) => a.data.reihenfolge - b.data.reihenfolge),
})).filter(g => g.links.length > 0);
---
<BaseLayout title="Links" description="Nützliche Links rund um Solarenergie, Umwelt und die Region Bonstetten.">

  <!-- Hero -->
  <div class="relative overflow-hidden" style="padding: 11rem 0 5rem">
    <div class="hero-bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>
    <div class="container">
      <span class="badge">Weiterführende Infos</span>
      <h1 class="mb-4">Links</h1>
      <p class="text-lg text-slate-500 max-w-lg leading-relaxed">
        Nützliche Links rund um Solarenergie, Umwelt und die Region Bonstetten.
      </p>
    </div>
  </div>

  <!-- Links -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {gruppiertLinks.map(gruppe => (
          <div class="flex flex-col gap-4">

            <!-- Kategorie-Titel -->
            <h2 class="flex items-center gap-3 text-xl font-bold pb-3 border-b-2 border-amber-400 mb-2">
              <span class="text-2xl">{gruppe.icon}</span>
              {gruppe.name}
            </h2>

            <!-- Link-Liste -->
            <ul class="flex flex-col gap-3 list-none p-0 m-0">
              {gruppe.links.map(link => (
                <li>
                  <a
                    href={link.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center justify-between gap-4 px-5 py-4 rounded-xl border border-slate-100 bg-white shadow-sm no-underline transition-all duration-300 hover:border-amber-400 hover:shadow-md hover:translate-x-1"
                  >
                    <div class="flex flex-col gap-0.5 overflow-hidden min-w-0">
                      <span class="font-semibold text-slate-900 text-[0.95rem]">
                        {link.data.title}
                      </span>
                      <span class="text-sm text-slate-500">
                        {link.data.beschreibung}
                      </span>
                      <span class="text-xs text-amber-700 truncate">
                        {link.data.url.replace(/^https?:\/\/(www\.)?/, '')}
                      </span>
                    </div>
                    <span class="text-lg text-amber-700 shrink-0 transition-transform duration-300 group-hover:translate-x-1">
                      →
                    </span>
                  </a>
                </li>
              ))}
            </ul>

          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
